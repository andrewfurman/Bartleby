# Public Worker URL after deploy.
BARTLEBY_PUBLIC_BASE_URL=https://bartleby.<your-subdomain>.workers.dev

# Shared auth for ElevenLabs tool calls.
BARTLEBY_TOOL_TOKEN=replace-with-long-random-token

# Admin API for transcript lookup.
ADMIN_TOKEN=replace-with-long-random-token

# Twilio inbound webhook protection and caller allow-list.
TWILIO_WEBHOOK_TOKEN=replace-with-long-random-token
ALLOWED_CALLER_NUMBERS=+15555550123
OUTSIDE_COVERAGE_MESSAGE=This number is for Andrew's Bartleby bot.

# Twilio provisioning and optional automated test calls.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=replace-with-twilio-api-key-secret
TWILIO_AREA_CODE=
TWILIO_POSTAL_CODE=10001
TWILIO_REQUIRE_SMS=false
TWILIO_PURCHASE_CONFIRM=false
BARTLEBY_TWILIO_PHONE_NUMBER=
TEST_CALL_FROM_NUMBER=

# ElevenLabs voice agent and post-call transcript webhook.
ELEVENLABS_API_KEY=replace-with-elevenlabs-api-key
ELEVENLABS_AGENT_ID=
ELEVENLABS_API_BASE=https://api.elevenlabs.io
ELEVENLABS_TELEPHONY_AUDIO_FORMAT=ulaw_8000
ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9
ELEVENLABS_FIRST_MESSAGE={{bartleby_greeting}}
ELEVENLABS_POST_CALL_WEBHOOK_ID=
ELEVENLABS_POST_CALL_TOKEN=replace-with-long-random-token
# Optional HMAC verification if using ElevenLabs HMAC webhooks.
ELEVENLABS_WEBHOOK_SECRET=

# The Economist RSS feed. Store the real private URL only in secrets/env, not in Git.
ECONOMIST_RSS_URL=https://example.com/private-economist-feed.xml?token=replace-me
ECONOMIST_RSS_BEARER_TOKEN=
ECONOMIST_RSS_CACHE_SECONDS=900
ECONOMIST_RSS_TIMEOUT_MS=25000
BARTLEBY_BOOTSTRAP_ARTICLE_LIMIT=200
BARTLEBY_BOOTSTRAP_MAX_CHARS=60000
BARTLEBY_GREETING_TEMPLATE=Hey, it's Bartleby. Just checking the headlines right now. The top two stories from the most recent World in Brief are story number one, {story_1}, and story number two, {story_2}.

# Outside-web fallback. Tavily is optional; without it Bartleby uses DuckDuckGo Instant Answer,
# then DuckDuckGo HTML results, then Bing HTML results if the instant-answer API is sparse.
WEB_SEARCH_PROVIDER=auto
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic
